{% extends "base.html.j2" %}
{% block title %}WIP — GLPI Nagbot{% endblock %}
{% block content %}
<h1>Team WIP</h1>
{% if run is none %}
<div class="empty">
  <p>No data yet — the nagbot hasn't completed a run.</p>
  <p><a href="/ops">Go to Ops</a> to trigger one.</p>
</div>
{% else %}
<p class="muted">
  As of {{ run.started_at|localdt }} — run #{{ run.id }}
  {% if run.dry_run %}<span class="badge dry_run">DRY-RUN</span>{% endif %}
</p>

<p><strong>{{ rollup.total_open }}</strong> open tickets</p>
<div class="distribution" title="tier distribution">
  {% for tier in Tier %}
    {% if rollup.distribution[tier] %}
    <div class="{{ tier.value }}" style="flex:{{ rollup.distribution[tier] }};">
      {{ tier_emoji[tier] }} {{ rollup.distribution[tier] }}
    </div>
    {% endif %}
  {% endfor %}
</div>

<h2>WIP per person</h2>
<table>
  <tr>
    <th>Owner</th><th class="num">Open</th><th>Tiers</th>
    <th class="num">Oldest</th><th class="num">Worst stale</th>
  </tr>
  {% for p in rollup.per_person %}
  <tr>
    <td><a href="/wip/{{ p.owner_key|urlencode }}">{{ p.owner_name }}</a></td>
    <td class="num">{{ p.total }}</td>
    <td>{% for tier in Tier %}{% if p.counts[tier] %}<span class="badge {{ tier.value }}">{{ tier_emoji[tier] }} {{ p.counts[tier] }}</span> {% endif %}{% endfor %}</td>
    <td class="num">{{ p.oldest_age_bd|days }}</td>
    <td class="num">{{ p.worst_stale_bd|days }}</td>
  </tr>
  {% endfor %}
</table>

<h2>Oldest tickets (the leaderboard nobody wants to top)</h2>
<table>
  <tr>
    <th></th><th>Ticket</th><th>Title</th><th>Owner</th>
    <th class="num">Age</th><th class="num">No update</th>
  </tr>
  {% for s in rollup.leaderboard %}
  <tr>
    <td>{{ tier_emoji[Tier(s.tier)] }}</td>
    <td><a href="/tickets/{{ s.ticket_id }}">#{{ s.ticket_id }}</a>
        {% if s.ticket_id in snoozes %}<span title="snoozed">💤</span>{% endif %}
        {% if s.ticket_id in escalated %}<span title="manager CC'd">⚠️</span>{% endif %}</td>
    <td><a href="{{ glpi_web_base }}/front/ticket.form.php?id={{ s.ticket_id }}">{{ s.title }}</a></td>
    <td>{{ s.owner_name }}</td>
    <td class="num">{{ s.age_bd|days }}</td>
    <td class="num">{{ s.stale_bd|days }}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}
{% endblock %}
