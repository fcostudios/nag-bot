{% import "_macros.j2" as m %}
<div style="font-family:Segoe UI,Arial,sans-serif;font-size:14px;color:#212121;max-width:720px;">
  <p style="margin:0 0 4px 0;">Hi {{ d.owner.display_name }},</p>
  <p style="margin:0 0 12px 0;">
    You have <strong>{{ d.tickets|length }}</strong> open ticket{{ 's' if d.tickets|length != 1 }}
    {%- if d.counts[Tier.ON_FIRE] %} — <span style="color:#c62828;font-weight:bold;">🔴 {{ d.counts[Tier.ON_FIRE] }} need{{ 's' if d.counts[Tier.ON_FIRE] == 1 }} immediate attention</span>{% endif -%}
    {%- if d.counts[Tier.HOT] %}, 🟠 {{ d.counts[Tier.HOT] }} heating up{% endif %}.
    Stale tickets hurt the whole queue — a one-line update today keeps them moving.
  </p>
  {% if d.escalated %}
  <p style="margin:0 0 12px 0;padding:8px;background:#ffebee;border-left:4px solid #c62828;">
    ⚠️ {{ d.escalated|length }} ticket{{ 's' if d.escalated|length != 1 }} stalled long enough that your manager is CC'd on this digest:
    {% for s in d.escalated %}<a href="{{ s.ticket.url }}">#{{ s.ticket.id }}</a>{{ ", " if not loop.last }}{% endfor %}
  </p>
  {% endif %}
  <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;border:1px solid #e0e0e0;">
    <tr style="background:#f5f5f5;text-align:left;">
      <th style="padding:6px 8px;"></th>
      <th style="padding:6px 8px;">Ticket</th>
      <th style="padding:6px 8px;">Title</th>
      <th style="padding:6px 8px;text-align:right;">Age</th>
      <th style="padding:6px 8px;text-align:right;">No update</th>
      {% if d.has_sla_tickets %}<th style="padding:6px 8px;">SLA</th>{% endif %}
    </tr>
    {% for s in d.tickets %}
    {{ m.ticket_row_html(s, d.has_sla_tickets) }}
    {% endfor %}
  </table>
  <p style="margin:12px 0 0 0;color:#757575;font-size:12px;">
    Age/no-update are business days ({{ d.generated_at|localdt }}).
    Ticket blocked? Ask your lead to snooze it on the nagbot dashboard.
  </p>
</div>
