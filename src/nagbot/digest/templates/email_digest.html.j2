{% import "_macros.j2" as m %}
<div style="font-family:Barlow,'Segoe UI',Arial,sans-serif;font-size:14px;color:#595756;max-width:720px;">
  <div style="border-top:4px solid #e7851a;padding-top:12px;margin-bottom:16px;">
    <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#949394;">Quito Publishing House · Nagbot</div>
  </div>
  <p style="margin:0 0 4px 0;">Hi {{ d.owner.display_name }},</p>
  <p style="margin:0 0 12px 0;">
    You have <strong>{{ d.tickets|length }}</strong> open ticket{{ 's' if d.tickets|length != 1 }}
    {%- if d.counts[Tier.ON_FIRE] %} — <span style="color:#d64545;font-weight:bold;">🔴 {{ d.counts[Tier.ON_FIRE] }} need{{ 's' if d.counts[Tier.ON_FIRE] == 1 }} immediate attention</span>{% endif -%}
    {%- if d.counts[Tier.HOT] %}, 🟠 {{ d.counts[Tier.HOT] }} heating up{% endif %}.
    Stale tickets hurt the whole queue — a one-line update today keeps them moving.
  </p>
  {% if d.escalated %}
  <p style="margin:0 0 12px 0;padding:10px 12px;background:#fbe0e0;border-left:4px solid #d64545;border-radius:8px;">
    ⚠️ {{ d.escalated|length }} ticket{{ 's' if d.escalated|length != 1 }} stalled long enough that your manager is CC'd on this digest:
    {% for s in d.escalated %}<a href="{{ s.ticket.url }}" style="color:#c96f12;">#{{ s.ticket.id }}</a>{{ ", " if not loop.last }}{% endfor %}
  </p>
  {% endif %}
  <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;border:1px solid #e3e2e2;border-radius:12px;overflow:hidden;">
    <tr style="background:#f2f2f2;text-align:left;color:#595756;">
      <th style="padding:8px;"></th>
      <th style="padding:8px;font-weight:600;">Ticket</th>
      <th style="padding:8px;font-weight:600;">Title</th>
      <th style="padding:8px;text-align:right;font-weight:600;">Age</th>
      <th style="padding:8px;text-align:right;font-weight:600;">No update</th>
      {% if d.has_sla_tickets %}<th style="padding:8px;font-weight:600;">SLA</th>{% endif %}
    </tr>
    {% for s in d.tickets %}
    {{ m.ticket_row_html(s, d.has_sla_tickets) }}
    {% endfor %}
  </table>
  <p style="margin:12px 0 0 0;color:#787474;font-size:12px;">
    Age/no-update are business days ({{ d.generated_at|localdt }}).
    Ticket blocked? Ask your lead to snooze it on the nagbot dashboard.
  </p>
</div>
