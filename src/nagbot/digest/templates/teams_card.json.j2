{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": {{ subject | tojson }}
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "text": {{ ("Ticket digest for " ~ d.owner.display_name ~ " — worst first, business-day ages.") | tojson }}
    },
    {
      "type": "FactSet",
      "facts": [
        {% for s in d.tickets %}
        {
          "title": {{ (tier_emoji[s.tier] ~ " #" ~ s.ticket.id) | tojson }},
          "value": {{ ("[" ~ s.ticket.title ~ "](" ~ s.ticket.url ~ ") — age " ~ s.metrics.age_bd|days ~ ", no update " ~ s.metrics.stale_bd|days) | tojson }}
        }{{ "," if not loop.last }}
        {% endfor %}
      ]
    }
  ]
}
