{% import "_macros.j2" as m %}
<div style="font-family:Barlow,'Segoe UI',Arial,sans-serif;font-size:14px;color:#595756;max-width:760px;">
  <div style="border-top:4px solid #e7851a;padding-top:12px;margin-bottom:12px;">
    <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#949394;">Corporativo · Nagbot</div>
  </div>
  <h2 style="margin:0 0 8px 0;font-weight:900;text-transform:uppercase;letter-spacing:-0.01em;color:#595756;">Weekly WIP rollup</h2>
  <p style="margin:0 0 12px 0;">
    <strong>{{ r.total_open }}</strong> open tickets —
    {% for tier in Tier %}{{ tier_emoji[tier] }} {{ r.distribution[tier] }}{{ " · " if not loop.last }}{% endfor %}
  </p>

  <h3 style="margin:16px 0 6px 0;font-weight:700;color:#595756;">WIP per person</h3>
  <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;border:1px solid #e3e2e2;border-radius:12px;overflow:hidden;">
    <tr style="background:#f2f2f2;text-align:left;color:#595756;">
      <th style="padding:8px;font-weight:600;">Owner</th>
      <th style="padding:8px;text-align:right;font-weight:600;">Open</th>
      <th style="padding:8px;font-weight:600;">Tiers</th>
      <th style="padding:8px;text-align:right;font-weight:600;">Oldest</th>
      <th style="padding:8px;text-align:right;font-weight:600;">Worst stale</th>
    </tr>
    {% for p in r.per_person %}
    <tr>
      <td style="padding:6px 8px;">{{ p.owner_name }}</td>
      <td style="padding:6px 8px;text-align:right;">{{ p.total }}</td>
      <td style="padding:6px 8px;">{% for tier in Tier %}{% if p.counts[tier] %}{{ tier_emoji[tier] }}{{ p.counts[tier] }} {% endif %}{% endfor %}</td>
      <td style="padding:6px 8px;text-align:right;">{{ p.oldest_age_bd|days }}</td>
      <td style="padding:6px 8px;text-align:right;">{{ p.worst_stale_bd|days }}</td>
    </tr>
    {% endfor %}
  </table>

  <h3 style="margin:16px 0 6px 0;font-weight:700;color:#595756;">Oldest tickets (worst offenders)</h3>
  <table cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;border:1px solid #e3e2e2;border-radius:12px;overflow:hidden;">
    <tr style="background:#f2f2f2;text-align:left;color:#595756;">
      <th style="padding:8px;"></th>
      <th style="padding:8px;font-weight:600;">Ticket</th>
      <th style="padding:8px;font-weight:600;">Title</th>
      <th style="padding:8px;font-weight:600;">Owner</th>
      <th style="padding:8px;text-align:right;font-weight:600;">Age</th>
      <th style="padding:8px;text-align:right;font-weight:600;">No update</th>
    </tr>
    {% for s in r.leaderboard %}
    <tr>
      <td style="padding:6px 8px;">{{ tier_emoji[Tier(s.tier)] }}</td>
      <td style="padding:6px 8px;white-space:nowrap;"><a href="{{ glpi_web_base }}/front/ticket.form.php?id={{ s.ticket_id }}" style="color:#c96f12;text-decoration:none;">#{{ s.ticket_id }}</a></td>
      <td style="padding:6px 8px;">{{ s.title }}</td>
      <td style="padding:6px 8px;">{{ s.owner_name }}</td>
      <td style="padding:6px 8px;text-align:right;">{{ s.age_bd|days }}</td>
      <td style="padding:6px 8px;text-align:right;">{{ s.stale_bd|days }}</td>
    </tr>
    {% endfor %}
  </table>
  <p style="margin:12px 0 0 0;color:#787474;font-size:12px;">Generated {{ r.generated_at|localdt }} — ages in business days.</p>
</div>
