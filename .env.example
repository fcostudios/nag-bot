# GLPI Nagbot — secrets & endpoints (copy to .env for docker compose)

# --- GLPI (required) ---
GLPI_BASE_URL=https://glpi.example.com/apirest.php
GLPI_APP_TOKEN=change-me
GLPI_USER_TOKEN=change-me

# --- Email channel ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM=nagbot@example.com

# --- Teams channel (Epic 5) ---
#TEAMS_WEBHOOK_URL=

# --- WhatsApp channel (Epic 6) ---
#WHATSAPP_TOKEN=
#WHATSAPP_PHONE_NUMBER_ID=
#WHATSAPP_TEMPLATE_NAME=

# --- Urgent P0 escalation (Epic 7) — self-hosted OpenWA sidecar ---
# See docs/e7-escalation-runbook.md. OPENWA_URL is the sidecar's HTTP API (compose network);
# OPENWA_WEBHOOK_SECRET authenticates inbound acks at POST /webhooks/openwa; pin the image tag.
#OPENWA_URL=http://openwa:8085
#OPENWA_WEBHOOK_SECRET=change-me
#OPENWA_IMAGE_TAG=            # a specific tag/digest — never "latest"

# --- Dashboard ---
DASHBOARD_PASSWORD=change-me

# --- Nagbot ---
NAGBOT_CONFIG_PATH=/config/nagbot.yaml
NAGBOT_DB_PATH=/data/nagbot.db
# Dry-run is the DEFAULT. Set to false (here AND channels.dry_run in the YAML) to send for real.
NAGBOT_DRY_RUN=true
NAGBOT_LOG_LEVEL=INFO
TZ=America/Guayaquil
